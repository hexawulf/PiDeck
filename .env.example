# PiDeck Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=5006

# Session Security
SESSION_SECRET=your-secure-session-secret-here

# Optional: Database Configuration (for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/pideck

# Log directory (defaults to $HOME/logs)
# PIDECK_LOGS_DIR=/home/zk/logs

# PM2 logs directory (defaults to $HOME/.pm2/logs)
# PM2_LOGS_DIR=/home/zk/.pm2/logs